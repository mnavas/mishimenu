############################################################
# MishiMenu — self-hosted docker-compose configuration
# Generated by: ./mishimenu install
# Do NOT edit manually unless you know what you're doing.
############################################################

# --- Postgres ---
POSTGRES_PASSWORD=change-me-strong-password

# --- JWT (shared between Kong, GoTrue, PostgREST) ---
# Must be at least 32 characters
JWT_SECRET=change-me-at-least-32-chars-random-string
JWT_EXPIRY=3600

# --- Supabase service keys (generated by ./mishimenu install) ---
ANON_KEY=
SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
OCR_INTERNAL_SECRET=change-me-random-string

# --- Supabase internal URLs (used by Next.js container) ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}

# --- Site URL used by GoTrue for redirect callbacks ---
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

# --- Restaurant info (written by ./mishimenu install, read by ./mishimenu seed) ---
RESTAURANT_NAME=
RESTAURANT_ADDRESS=
RESTAURANT_PHONE=
RESTAURANT_RUC=

# Payment settings
# policy: upfront (pay before cooking) or at_end (pay after eating)
RESTAURANT_PAYMENT_POLICY=upfront
# Comma-separated list of accepted methods: deuna, sipi, transfer, cash, card
RESTAURANT_ACCEPTED_PAYMENTS=deuna,cash

# DeUna digital wallet (Banco Pichincha)
RESTAURANT_DEUNA_QR_URL=
RESTAURANT_DEUNA_ACCOUNT_NAME=

# Sipi digital wallet (optional)
RESTAURANT_SIPI_QR_URL=
RESTAURANT_SIPI_ACCOUNT_NAME=

# Bank transfer (optional)
RESTAURANT_TRANSFER_BANK=
RESTAURANT_TRANSFER_ACCOUNT_NUMBER=
RESTAURANT_TRANSFER_ACCOUNT_NAME=

# Owner login (used by ./mishimenu install)
OWNER_EMAIL=
